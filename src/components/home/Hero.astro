---
interface Props {
  title: string;
  subtitle: string;
  ctaText: string;
  ctaLink: string;
  image: string;
}

const { title, subtitle, ctaText, ctaLink, image } = Astro.props;
---

<section class="relative h-[80vh] min-h-[600px] flex items-center overflow-hidden">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <img 
      src={image} 
      alt="Hero Background" 
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-brand-primary/60 to-transparent"></div>
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-2xl text-white">
      <div class="overflow-hidden">
        <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 animate-slide-up">
          {title}
        </h1>
      </div>
      <p class="text-xl md:text-2xl text-slate-200 mb-10 max-w-lg leading-relaxed animate-fade-in animation-delay-300">
        {subtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 animate-fade-in animation-delay-600">
        <a href={ctaLink} class="btn btn-primary btn-lg px-8 bg-brand-accent border-brand-accent text-brand-primary font-bold hover:scale-105 transition-transform">
          {ctaText}
        </a>
        <a href="/catalog" class="btn btn-outline btn-lg px-8 text-white border-white hover:bg-white hover:text-brand-primary transition-all">
          Explorar Catálogo
        </a>
      </div>
    </div>
  </div>

  <!-- Decorative element -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
    <div class="w-px h-12 bg-white/30 whitespace-nowrap"></div>
  </div>
</section>

<style>
  @keyframes slide-up {
    from { transform: translateY(100%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  
  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .animate-slide-up {
    animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  
  .animate-fade-in {
    animation: fade-in 1s ease-out forwards;
    opacity: 0;
  }
  
  .animation-delay-300 {
    animation-delay: 300ms;
  }
  
  .animation-delay-600 {
    animation-delay: 600ms;
  }
</style>
