---
import { ShoppingCart, Eye } from 'lucide-react';

interface Props {
  id: string;
  name: string;
  price: number;
  image?: string;
  image_url?: string;
  category?: string;
  categories?: { name: string } | null;
  isNew?: boolean;
  onSale?: boolean;
}

const { id, name, price, image, image_url, category, categories, isNew, onSale } = Astro.props;

const displayImage = image_url || image || '/images/placeholder.png';
const displayCategory = categories?.name || category || 'General';

const formattedPrice = new Intl.NumberFormat('es-CL', {
  style: 'currency',
  currency: 'CLP',
}).format(price);
---

<div class="premium-card group relative flex flex-col h-full bg-white rounded-2xl overflow-hidden border border-slate-100 hover:shadow-xl transition-all duration-300">
  <a href={`/product/${id}`} class="flex-grow">
    <div class="relative overflow-hidden aspect-square bg-slate-50">
      <!-- Badges -->
      <div class="absolute top-2 left-2 z-10 flex flex-col gap-1">
        {isNew && <span class="badge badge-primary badge-xs font-bold px-2 py-1">NUEVO</span>}
        {onSale && <span class="badge badge-accent badge-xs font-bold text-brand-primary px-2 py-1">OFERTA</span>}
      </div>
      
      <!-- Image -->
      <img 
        src={displayImage} 
        alt={name} 
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        loading="lazy"
      />
    </div>
    
    <div class="p-3 sm:p-4">
      <div class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1">
        {displayCategory}
      </div>
      <h3 class="font-bold text-sm sm:text-base mb-1 text-brand-primary truncate group-hover:text-brand-accent transition-colors">
        {name}
      </h3>
      <div class="flex items-center justify-between">
        <span class="text-base sm:text-lg font-bold text-brand-primary">{formattedPrice}</span>
      </div>
    </div>
  </a>
  
  <!-- Add to Cart Button (Mobile visible, Desktop hover) -->
  <div class="absolute top-2 right-2 flex flex-col gap-2 opacity-100 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity">
    <button 
      class="add-to-cart-btn btn btn-circle btn-sm btn-primary shadow-lg border-none hover:scale-110"
      data-id={id}
      data-name={name}
      data-price={price}
      data-image={displayImage}
    >
      <ShoppingCart className="w-4 h-4" />
    </button>
  </div>
</div>

<script>
  import { addCartItem } from '@/store/cart';

  function initButtons() {
    const buttons = document.querySelectorAll('.add-to-cart-btn');
    buttons.forEach((btn) => {
      // Evitar duplicar listeners
      if (btn.getAttribute('data-active')) return;
      btn.setAttribute('data-active', 'true');

      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        
        const { id, name, price, image } = (btn as HTMLElement).dataset;
        if (id && name && price && image) {
          addCartItem({
            id,
            name,
            price: Number(price),
            image,
          });
        }
      });
    });
  }

  // Ejecutar en carga inicial y después de navegación Astro
  initButtons();
  document.addEventListener('astro:page-load', initButtons);
</script>
