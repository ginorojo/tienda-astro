---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { supabaseAdmin } from '@/lib/supabaseServer';
import { ArrowLeft, Package, User, MapPin, CreditCard } from 'lucide-react';
import type { Order, OrderItem } from '@/types/database';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin/orders');
}

// Fetch order
const { data: orderData, error: orderError } = await supabaseAdmin
  .from('orders')
  .select('*')
  .eq('id', id)
  .single();

if (orderError || !orderData) {
  return Astro.redirect('/admin/orders');
}

const order = orderData as Order;

// Fetch order items
const { data: itemsData } = await supabaseAdmin
  .from('order_items')
  .select('*')
  .eq('order_id', id);

const items = (itemsData || []) as OrderItem[];

const getStatusBadge = (status: string) => {
  switch (status) {
    case 'paid': return 'badge-success';
    case 'pending': return 'badge-warning';
    case 'failed': return 'badge-error';
    case 'refunded': return 'badge-neutral';
    default: return 'badge-ghost';
  }
};
---

<BaseLayout title={`Detalle de Orden #${order.flow_order_id || id.slice(0, 8)} | Admin`}>
  <div class="container mx-auto px-4 py-12 max-w-4xl">
    <a href="/admin/orders" class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-brand-primary transition-colors mb-6">
      <ArrowLeft className="w-4 h-4" />
      Volver a las órdenes
    </a>

    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-bold text-brand-primary flex items-center gap-3">
          Orden #{order.flow_order_id || id.slice(0, 8)}
          <span class={`badge ${getStatusBadge(order.status)} badge-lg`}>{order.status}</span>
        </h1>
        <p class="text-slate-500 mt-1">Realizada el {new Date(order.created_at).toLocaleString('es-CL')}</p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <!-- Detalles del cliente -->
      <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
        <h3 class="font-bold flex items-center gap-2 text-lg mb-4 text-slate-800">
          <User className="w-5 h-5 text-brand-primary" />
          Cliente
        </h3>
        <div class="space-y-2 text-sm">
          <p><span class="text-slate-500">Nombre:</span> <span class="font-medium">{order.customer_name || 'No especificado'}</span></p>
          <p><span class="text-slate-500">Email:</span> <span class="font-medium">{order.customer_email || 'No especificado'}</span></p>
        </div>
      </div>

      <!-- Detalles de envío -->
      <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
        <h3 class="font-bold flex items-center gap-2 text-lg mb-4 text-slate-800">
          <MapPin className="w-5 h-5 text-brand-primary" />
          Despacho
        </h3>
        <div class="space-y-2 text-sm">
          <p><span class="text-slate-500">Región:</span> <span class="font-medium">{order.region || 'No especificada'}</span></p>
          <p><span class="text-slate-500">Comuna:</span> <span class="font-medium">{order.comuna || 'No especificada'}</span></p>
          <p><span class="text-slate-500">Dirección:</span> <span class="font-medium">{order.address || 'No especificada'}</span></p>
          {order.tracking_number && (
            <p class="mt-4 pt-4 border-t border-slate-100">
              <span class="text-slate-500">Tracking:</span> <span class="font-mono bg-slate-100 px-2 py-1 rounded text-slate-700">{order.tracking_number}</span>
            </p>
          )}
        </div>
      </div>
    </div>

    <!-- Productos -->
    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden mb-8">
      <div class="p-6 border-b border-slate-100 bg-slate-50/50 flex items-center gap-2">
        <Package className="w-5 h-5 text-brand-primary" />
        <h3 class="font-bold text-lg text-slate-800">Productos ({items.length})</h3>
      </div>
      <div class="overflow-x-auto">
        <table class="table">
          <thead>
            <tr class="bg-slate-50 text-slate-500">
              <th>Producto</th>
              <th class="text-right">Precio Unitario</th>
              <th class="text-center">Cantidad</th>
              <th class="text-right">Subtotal</th>
            </tr>
          </thead>
          <tbody>
            {items.map((item) => (
              <tr>
                <td class="font-medium">{item.product_name || 'Producto Desconocido'}</td>
                <td class="text-right text-slate-600">{new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP' }).format(item.price)}</td>
                <td class="text-center">
                  <div class="badge badge-neutral">{item.quantity}</div>
                </td>
                <td class="text-right font-bold">
                  {new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP' }).format(item.price * item.quantity)}
                </td>
              </tr>
            ))}
            {items.length === 0 && (
              <tr>
                <td colspan="4" class="text-center py-8 text-slate-400 italic">No hay productos registrados para esta orden.</td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Resumen de pago -->
    <div class="bg-brand-primary p-6 rounded-2xl shadow-sm text-white flex flex-col sm:flex-row justify-between items-center gap-4">
      <div class="flex items-center gap-3">
        <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center">
          <CreditCard className="w-6 h-6 text-white" />
        </div>
        <div>
          <h3 class="font-bold text-lg">Resumen de Pago</h3>
          <p class="text-white/70 text-sm">Medio: {order.payment_method || 'Por definir'}</p>
        </div>
      </div>
      <div class="text-right">
        <p class="text-white/70 text-sm mb-1">Total a Pagar</p>
        <p class="text-3xl font-bold">{new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP' }).format(order.total)}</p>
      </div>
    </div>
  </div>
</BaseLayout>
