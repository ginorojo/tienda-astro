---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { User } from 'lucide-react';

// Si ya hay sesión, redirigir al admin
const accessToken = Astro.cookies.get("sb-access-token");
const refreshToken = Astro.cookies.get("sb-refresh-token");

if (accessToken && refreshToken) {
  return Astro.redirect("/admin");
}
---

<BaseLayout title="Iniciar Sesión | Panel Admin">
  <div class="relative min-h-[calc(100vh-64px)] flex items-center justify-center bg-[#0a0a0c] overflow-hidden">
    <!-- Background Image with Strong Overlay -->
    <div 
      class="absolute inset-0 z-0 bg-cover bg-center bg-no-repeat scale-110"
      style="background-image: url('/images/login-bg.png');"
    >
      <!-- Gradient overlay for deep contrast -->
      <div class="absolute inset-0 bg-gradient-to-br from-black/80 via-black/60 to-primary/20 backdrop-blur-[4px]"></div>
    </div>

    <!-- Login Card -->
    <div class="relative z-10 w-full max-w-md px-6 animate-fade-in-up">
      <div class="bg-black/60 backdrop-blur-2xl border border-white/10 rounded-[2rem] shadow-[0_32px_64px_-16px_rgba(0,0,0,0.6)] overflow-hidden p-8 sm:p-12">
        <div class="text-center mb-10">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-primary/20 border border-primary/30 mb-6 mx-auto">
            <User className="w-8 h-8 text-primary" />
          </div>
          <h1 class="text-4xl font-bold tracking-tight text-white mb-3">Bienvenido</h1>
          <p class="text-slate-400 font-medium">Acceso exclusivo para administradores</p>
        </div>

        <form id="login-form" class="space-y-6">
          <div class="form-control">
            <label class="label pb-2">
              <span class="label-text font-semibold text-slate-300">Correo Electrónico</span>
            </label>
            <input 
              type="email" 
              name="email" 
              placeholder="admin@tienda.com" 
              class="input input-bordered h-14 bg-white/5 border-white/20 text-white placeholder:text-slate-600 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all rounded-2xl w-full" 
              required 
            />
          </div>

          <div class="form-control">
            <label class="label pb-2">
              <span class="label-text font-semibold text-slate-300">Contraseña</span>
            </label>
            <div class="relative">
              <input 
                type="password" 
                name="password" 
                placeholder="••••••••" 
                class="input input-bordered h-14 bg-white/5 border-white/20 text-white placeholder:text-slate-600 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all rounded-2xl w-full pr-12" 
                required 
              />
            </div>
            <label class="label justify-end pt-2">
              <a href="#" class="text-xs font-medium link link-hover text-slate-500 hover:text-primary transition-colors">¿Olvidaste tu contraseña?</a>
            </label>
          </div>

          <!-- Contenedor Toast para notificaciones -->
          <div id="toast-container" class="toast toast-top toast-center z-50 hidden">
            <div id="toast-message" class="alert shadow-lg text-white font-medium">
              <span id="toast-icon" class="mr-2"></span>
              <span id="toast-text"></span>
            </div>
          </div>

          <button 
            type="submit" 
            id="submit-btn"
            class="btn btn-primary w-full h-14 rounded-2xl text-lg font-bold shadow-2xl shadow-primary/25 hover:shadow-primary/40 transition-all active:scale-[0.97] border-none group relative overflow-hidden"
          >
            <span id="btn-text" class="flex items-center justify-center gap-2">
              Iniciar Sesión
            </span>
            <div id="btn-loader" class="hidden absolute inset-0 flex items-center justify-center bg-primary">
              <span class="loading loading-spinner loading-md"></span>
            </div>
          </button>
        </form>

        <div class="mt-10 pt-8 border-t border-white/5 text-center">
          <p class="text-xs font-semibold uppercase tracking-widest text-slate-600">Tienda Astro &copy; 2024</p>
        </div>
      </div>
    </div>

    <!-- Enhanced Decorative Elements -->
    <div class="absolute top-1/4 -left-20 w-96 h-96 bg-primary/30 rounded-full blur-[160px] z-0 animate-pulse"></div>
    <div class="absolute bottom-1/4 -right-20 w-[30rem] h-[30rem] bg-indigo-600/20 rounded-full blur-[180px] z-0 animate-pulse" style="animation-delay: 2s;"></div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('login-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text');
  const btnLoader = document.getElementById('btn-loader');
  const toastContainer = document.getElementById('toast-container');
  const toastMessage = document.getElementById('toast-message');
  const toastText = document.getElementById('toast-text');
  const toastIcon = document.getElementById('toast-icon');

  function showToast(message: string, isSuccess: boolean) {
    if (!toastContainer || !toastMessage || !toastText || !toastIcon) return;
    
    toastText.textContent = message;
    
    if (isSuccess) {
      toastMessage.className = "alert alert-success shadow-lg text-white font-medium animate-fade-in-up";
      toastIcon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`;
    } else {
      toastMessage.className = "alert alert-error shadow-lg text-white font-medium animate-fade-in-up animate-shake";
      toastIcon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`;
    }
    
    toastContainer.classList.remove('hidden');
    
    // Hide toast after 4 seconds if it's an error
    if (!isSuccess) {
      setTimeout(() => {
        toastContainer.classList.add('hidden');
      }, 4000);
    }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Reset state
    toastContainer?.classList.add('hidden');
    submitBtn.disabled = true;
    btnText?.classList.add('opacity-0');
    btnLoader?.classList.remove('hidden');

    const formData = new FormData(form);
    
    try {
      const response = await fetch('/api/auth/signin', {
        method: 'POST',
        body: formData,
      });

      if (response.ok) {
        showToast('¡Acceso aprobado! Redirigiendo al panel...', true);
        setTimeout(() => {
          window.location.href = '/admin';
        }, 1500);
      } else {
        const text = await response.text();
        let errorMessage = 'Error en el inicio de sesión';
        if (text.includes('Invalid login credentials')) {
          errorMessage = 'Correo o contraseña incorrectos';
        } else if (text) {
          errorMessage = text;
        }
        showToast(errorMessage, false);
      }
    } catch (err) {
      showToast('Error de conexión con el servidor', false);
    } finally {
      submitBtn.disabled = false;
      btnText?.classList.remove('opacity-0');
      btnLoader?.classList.add('hidden');
    }
  });
</script>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    animation: fade-in-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
